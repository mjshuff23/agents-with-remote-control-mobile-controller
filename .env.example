ARC_HOST="127.0.0.1"
ARC_PORT="3000"
ARC_REPO_PATH="/absolute/path/to/agents-with-remote-control-mobile-controller"
ARC_RUNNER_MODE="local"
ARC_CODEX_IGNORE_USER_CONFIG="true"
ARC_CODEX_ARGS_JSON="[\"exec\",\"--json\",\"--cd\",\"{repoPath}\",\"-\"]"
ARC_CODEX_COMMAND="codex"
ARC_CODEX_ENV_KEYS=""
ARC_LOG_TAIL_LIMIT="200"
ARC_SHUTDOWN_GRACE_MS="2000"
# Worktree root directory; empty uses "<dirname(ARC_REPO_PATH)>/worktrees"
ARC_WORKTREE_ROOT=""
# Phase 3 cooperative-gating policy file; relative paths resolve from ARC_REPO_PATH
ARC_POLICY_PATH="arc.config.json"
# Approval request timeout in milliseconds; default is 5 minutes
ARC_APPROVAL_TIMEOUT_MS="300000"
# Configured test command timeout ceiling in milliseconds; default is 10 minutes
ARC_TEST_COMMAND_TIMEOUT_MS="600000"
# Dormant session timeout in milliseconds (default 30 minutes)
ARC_DORMANT_TIMEOUT_MS="1800000"
# How often to check for idle sessions (default 60 seconds)
ARC_DORMANT_CHECK_INTERVAL_MS="60000"
ARC_WSL_COMMAND="wsl.exe"
ARC_WSL_DISTRO=""
ARC_WSL_USER=""
DATABASE_URL="file:./data/arc.sqlite"
CONTROLLER_SECRET=""

# GitHub fine-grained PAT (min scopes: issues:read, contents:write, pull_requests:write)
ARC_GITHUB_TOKEN=""
ARC_GITHUB_OWNER=""
ARC_GITHUB_REPO=""

# Linear personal API key (Settings > API > Personal API keys)
# Required scopes: issues:read, issues:write
# MVP uses personal API key; OAuth is the hardened option for multi-user deployments.
ARC_LINEAR_TOKEN=
