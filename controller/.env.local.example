# Local browser on the host:
# NEXT_PUBLIC_WS_URL=http://localhost:3000

# Phone over Tailscale or MagicDNS:
NEXT_PUBLIC_WS_URL=http://100.x.y.z:3000

# The Next.js server runs beside the orchestrator in WSL2, so proxy REST
# traffic to loopback instead of routing out through the Tailscale address.
BACKEND_URL=http://127.0.0.1:3000

# Use the same local controller bearer token in both places.
# This value is browser-visible through NEXT_PUBLIC_CONTROLLER_SECRET, so do
# not reuse provider tokens or any high-value credential here.
NEXT_PUBLIC_CONTROLLER_SECRET=<local-controller-secret>
CONTROLLER_SECRET=<local-controller-secret>
